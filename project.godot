; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="thermite-pathogen"
config/tags=PackedStringArray("main")
run/main_scene="uid://ig35f53rh73d"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="uid://bsm5nqj3kafye"

[debug]

gdscript/warnings/unused_parameter=0
gdscript/warnings/untyped_declaration=1
gdscript/warnings/unsafe_cast=1
gdscript/warnings/unsafe_call_argument=1

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="3d-survivals-like"

[editor]

movie_writer/movie_file="test.avi"
movie_writer/disable_vsync=true
script/templates_search_path="res://src/templates"

[editor_plugins]

enabled=PackedStringArray("res://addons/terrain_3d/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "blue",
"res://assets/": "orange",
"res://src/": "red"
}

[filesystem]

import/blender/enabled=false

[global_group]

player="player's group"

[importer_defaults]

texture={
"compress/channel_pack": 0,
"compress/hdr_compression": 1,
"compress/high_quality": false,
"compress/lossy_quality": 0.7,
"compress/mode": 2,
"compress/normal_map": 2,
"compress/rdo_quality_loss": 0.0,
"compress/uastc_level": 0,
&"detect_3d/compress_to": 1,
"mipmaps/generate": true,
"mipmaps/limit": -1,
"process/channel_remap/alpha": 3,
"process/channel_remap/blue": 2,
"process/channel_remap/green": 1,
"process/channel_remap/red": 0,
"process/fix_alpha_border": true,
"process/hdr_as_srgb": false,
"process/hdr_clamp_exposure": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"process/size_limit": 0,
"roughness/mode": 0,
"roughness/src_normal": ""
}

