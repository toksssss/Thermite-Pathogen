; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="thermite-pathogen"
run/main_scene="res://assets/main/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://bsm5nqj3kafye"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="3d-survivals-like"

[editor]

movie_writer/movie_file="test.avi"
movie_writer/disable_vsync=true
script/templates_search_path="res://src/templates"

[file_customization]

folder_colors={
"res://addons/": "blue",
"res://assets/": "orange",
"res://src/": "red"
}

[global_group]

player=""

[importer_defaults]

texture={
&"detect_3d/compress_to": 0
}

