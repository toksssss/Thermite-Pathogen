[sub_resource type="GDScript" id="GDScript_s53uv"]
script/source = "extends Label3D

@export var fsm : AIStateMachine
@export var hp : HealthComponent

func _physics_process(delta: float) -> void:
	text = \"\"
	text += \"State: \" + fsm.current_move.move_name
	text += \"HP: %10.3f\" % hp.health
"

