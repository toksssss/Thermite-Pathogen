[sub_resource type="GDScript" id="GDScript_hew67"]
resource_name = "dev"
script/source = "extends Label3D

@export var fsm: SoldierStateMachine
# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	text = \"\"
	text += \"State: %s\" % fsm.current_move.name
"

