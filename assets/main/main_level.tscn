[sub_resource type="GDScript" id="GDScript_7gh1c"]
resource_name = "stage_one_button"
script/source = "extends Area3D

var stage_machine : StageMachine

func _ready() -> void:
	stage_machine = StageMachine.instance
	area_entered.connect(_on_area_entered)

func _on_area_entered(area: Area3D) -> void:
	if area is Hurtbox:
		stage_machine.force_new_state(\"one\")
"

