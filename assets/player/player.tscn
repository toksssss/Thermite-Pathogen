[sub_resource type="GDScript" id="GDScript_xhr4e"]
resource_name = "hud_label"
script/source = "extends Label

@export var model : WeaponModel

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	text = \"%2d / %2d\" % [model.current_weapon_strategy._current_bullets, 
	model.current_weapon_strategy.weapon_data.bullet_capacity]
"

[sub_resource type="LabelSettings" id="LabelSettings_xhr4e"]
font_size = 55

[sub_resource type="GDScript" id="GDScript_bky8f"]
resource_name = "hp_label"
script/source = "extends Label


@export var hp : HealthComponent

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	text = \"HP: %2d\" % hp.health
"

